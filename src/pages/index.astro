---
import { getCollection, render } from 'astro:content';
const projects = await getCollection('projects');
---

<html lang="en">
    <head>
        <link rel="stylesheet" href="/css/styles.css" />
    </head>

    <body>
        <h1>Ryan Hausmann</h1>

        <h2>Projects</h2>
        <p style="margin-bottom: 0;">Find info on some of my projects below. Click on a project to find out more.</p>

        <div class="grid">
            { projects.map(async (project) => {
                const { Content } = await render(project);

                return (
                    <article class="card">
                        <header class="card-header">
                            <div class="title-group">
                                <h3 class="card-title">
                                    <a href={`/projects/${project.id}`} class="card-clickable-overlay">
                                        {project.data.title}
                                    </a>
                                </h3>

                                { project.data.githubUrl &&
                                    (<a href={project.data.githubUrl} target="_blank" rel="noopener noreferrer" class="github-link">
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                                            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                                        </svg>
                                    </a>
                                )}
                            </div>
                            
                            <span class="card-date">{project.data.dates}</span>
                        </header>

                        <p class="card-desc">{project.data.desc}</p>

                        { project.data.image && <img class="card-image" src={project.data.image} alt={project.data.title} /> }

                        <div class="card-tags">
                            { project.data.tags.map((tag) => 
                                <span class="tag-pill">{tag}</span>
                            )}
                        </div>
                    </article>
                )
            })}
        </div>
    </body>
</html>
