---
import { getCollection, render } from 'astro:content';
const projects = await getCollection('projects');
---

<html lang="en">
    <head>
        <style>
            /* Base card styling */
            .card {
                position: relative;
                border: 1px solid #e2e8f0;
                border-radius: 12px;
                padding: 1.5rem;
                background-color: #ffffff;
                display: flex;
                flex-direction: column;
                gap: 1rem; /* Creates even spacing between all child elements */
                transition: transform 0.2s ease, box-shadow 0.2s ease;
            }
            
            .card:hover {
                transform: translateY(-4px);
                box-shadow: 0 10px 15px rgba(0, 0, 0, 0.05);
            }
            
            .card-clickable-overlay {
                text-decoration: none;
                color: inherit;
            }

            .card-clickable-overlay::after {
                content: "";
                position: absolute;
                inset: 0; 
                z-index: 1; 
            }
            
            .card-header {
                display: flex;
                justify-content: space-between; 
                align-items: flex-start;
            }

            .title-group {
                display: flex;
                align-items: center;
                gap: 0.5rem;
            }
            
            .card-title {
                font-weight: 700;
                font-size: 1.25rem;
                margin: 0;
                color: #1a202c;
            }

            .github-link {
                position: relative;
                z-index: 2; /* Must be higher than the .card-clickable-overlay::after */
                display: inline-flex;
                color: #4a5568;
                transition: transform 0.2s ease, color 0.2s ease;
            }

            .github-link:hover {
                transform: scale(1.15) translateY(-1px);
                color: #1a202c;
                cursor: pointer;
            }
            
            .card-date {
                font-size: 0.875rem;
                color: #718096;
                white-space: nowrap; /* Prevents the date from wrapping to two lines */
            }
            
            .card-desc {
                margin: 0;
                color: #4a5568;
                font-size: 1rem;
                line-height: 1.5;
            }
            
            /* Forces image to fit nicely within the card */
            .card-image {
                width: 100%;
                height: 200px;
                object-fit: cover; /* Crops the image proportionally so it doesn't squish */
                border-radius: 6px;
            }
            
            /* Tag container */
            .card-tags {
                display: flex;
                flex-wrap: wrap; /* Allows tags to wrap to the next line if there are many */
                gap: 0.5rem;
                margin-top: auto; /* Pushes the tags to the very bottom of the card */
            }
            
            /* Individual stylized tags */
            .tag-pill {
                background-color: #edf2f7;
                color: #2b6cb0;
                font-size: 0.75rem;
                font-weight: 600;
                padding: 0.25rem 0.75rem;
                border-radius: 9999px; /* Creates perfectly rounded pill shapes */
            }

            .grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
                gap: 2rem;
                padding: 2rem 0;
            }

            body {
                max-width: 1200px;
                margin: 0 auto;
                padding: 0 5%;
                font-family: system-ui, sans-serif;
            }
        </style>
    </head>

    <body>
        <h1>My portfolio</h1>

        <div class="grid">
            { projects.map(async (project) => {
                const { Content } = await render(project);

                return (
                    <article class="card">
                        <header class="card-header">
                            <div class="title-group">
                                <h3 class="card-title">
                                    <a href={`/projects/${project.id}`} class="card-clickable-overlay">
                                        {project.data.title}
                                    </a>
                                </h3>

                                { project.data.githubUrl &&
                                    (<a href={project.data.githubUrl} target="_blank" rel="noopener noreferrer" class="github-link">
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                                            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
                                        </svg>
                                    </a>
                                )}
                            </div>
                            
                            <span class="card-date">{project.data.dates}</span>
                        </header>

                        <p class="card-desc">{project.data.desc}</p>

                        { project.data.image && <img class="card-image" src={project.data.image} alt={project.data.title} /> }

                        <div class="card-tags">
                            { project.data.tags.map((tag) => 
                                <span class="tag-pill">{tag}</span>
                            )}
                        </div>
                    </article>
                )
            })}
        </div>
    </body>
</html>
